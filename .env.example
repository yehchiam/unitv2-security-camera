# ── Camera Dashboard (Pi 4) ──────────────────────────────────────────
# Dashboard login credentials (REQUIRED for security!)
CAM_DASH_USER=admin
CAM_DASH_PASS=changeme

# Bind address: "0.0.0.0" for all interfaces (tunnel/LAN), "127.0.0.1" for localhost only
CAM_DASH_HOST=0.0.0.0
CAM_DASH_PORT=3006

# ── UnitV2 Connection ────────────────────────────────────────────────
# How the Pi 4 reaches the UnitV2 camera
UNITV2_HOST=192.168.100.134
UNITV2_PORT=8080
UNITV2_SSH_USER=root
UNITV2_SSH_PASS=YOUR_UNITV2_SSH_PASSWORD

# ── UnitV2 Camera Script ─────────────────────────────────────────────
# ntfy.sh topic for push notifications (e.g. camera-aac2619e80df)
NTFY_URL=https://ntfy.sh/YOUR_NTFY_TOPIC